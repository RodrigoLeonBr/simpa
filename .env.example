# =============================================================================
# SIMPA — Environment variables (copy to .env and fill in values)
# =============================================================================

# --- PostgreSQL (Docker service name: postgres) ---
PG_HOST=postgres
PG_PORT=5432
PG_DB=simpa
PG_USER=postgres
PG_PASS=change_me_in_production
PG_PUBLISH_PORT=5433

# For local scripts outside Docker, use:
# PG_HOST=localhost

# --- MySQL/XAMPP (SIA — read-only) ---
# From api container use host.docker.internal (configured in docker-compose)
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=
MYSQL_USER=
MYSQL_PASS=

# Optional SIA table/column overrides (defaults: s_prd, prestador, procedimento)
# SIA_TABLE_PRD=s_prd
# SIA_TABLE_PRESTADOR=prestador
# SIA_TABLE_PROCEDIMENTO=procedimento

# --- API ---
PORT=3001
NODE_ENV=production

# --- JWT (Task 04+) ---
JWT_SECRET=change_me_use_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# --- Python ETL ---
PYTHON_BIN=python3
UPLOAD_DIR=/app/uploads

# --- Frontend (Task 09+) ---
VITE_API_BASE=
