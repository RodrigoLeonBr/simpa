# =============================================================================
# SIMPA — Local environment variables (copy to .env and fill in values)
# =============================================================================

# --- PostgreSQL (host/local dev) ---
# Local (npm run dev / scripts fora do Docker): 127.0.0.1 + PG_PUBLISH_PORT.
# Docker Compose usa .env.docker e a rede interna do container.
PG_HOST=127.0.0.1
PG_PORT=5433
PG_PUBLISH_PORT=5433
PG_DB=simpa
PG_USER=postgres
PG_PASS=change_me_in_production

# --- MySQL/XAMPP (SIA — read-only) ---
# Dev local acessa o MySQL da maquina local diretamente.
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=producao
MYSQL_USER=
MYSQL_PASS=

# SIA schema overrides (defaults = banco producao/DATASUS: s_prd + prestador + procedimento)
# SIA_TABLE_PRD=s_prd
# SIA_TABLE_PRESTADOR=prestador
# SIA_TABLE_PROCEDIMENTO=procedimento
# SIA_COL_COMPETENCIA=prd_cmp
# SIA_COL_PRD_UID=prd_uid
# SIA_COL_PRESTADOR_PK=re_cunid
# SIA_COL_COD_PROC=prd_pa
# SIA_COL_PROC_PK=codigo
# SIA_COL_QTD=PRD_QT_A
# SIA_COL_VALOR=PRD_VL_A
# SIA_COL_IDADE=PRD_IDADE
# SIA_COL_CBO=prd_cbo
# SIA_COL_UNIDADE=re_cnome
# SIA_COL_DESC_PROC=procedimento
# SIA_COL_PRESTADOR_ATIVO=ativo
# SIA_COL_SEXO=          # vazio: s_prd não tem sexo → default 'I'

# Cadastro sync — perfil derivado de prestador.tipouni (migration 004)
# CADASTRO_PERFIL_MAP={"tipouni":{"1":"APS","2":"MAC","3":"Hospitalar"},"default":"Outro"}
# CADASTRO_SYNC_SCRIPT=/app/sync_cadastros_mysql.py

# --- API ---
PORT=3001
NODE_ENV=production

# --- JWT (Task 04+) ---
JWT_SECRET=change_me_use_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# --- Python ETL ---
PYTHON_BIN=python3
UPLOAD_DIR=/app/uploads

# --- Frontend (Vite local) ---
# Dev local (Vite :5173): http://localhost:3001
# Mock json-server: http://localhost:3100
VITE_API_BASE=
