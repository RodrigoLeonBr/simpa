# Stage 1 — build React SPA (same-origin API via nginx proxy)
FROM node:22-bookworm-slim AS frontend-build

WORKDIR /app/simpa-frontend

COPY simpa-frontend/package.json simpa-frontend/package-lock.json* ./
RUN npm ci

COPY simpa-frontend/ ./

# Empty base URL: browser calls /api and /auth on the same host (nginx → api)
ENV VITE_API_BASE=
RUN npm run build

# Stage 2 — nginx serves dist + reverse proxy
FROM nginx:1.27-alpine

COPY docker/nginx/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=frontend-build /app/simpa-frontend/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=10s --timeout=3s --retries=3 \
  CMD wget -q --spider http://127.0.0.1/ || exit 1
