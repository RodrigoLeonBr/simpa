# =============================================================================
# SIMPA — Docker environment variables (copy to .env.docker and fill in values)
# =============================================================================

# --- PostgreSQL (docker network) ---
PG_HOST=postgres
PG_PORT=5432
PG_PUBLISH_PORT=5433
PG_DB=simpa
PG_USER=postgres
PG_PASS=change_me_in_production

# --- MySQL/XAMPP (host machine from container) ---
MYSQL_HOST=host.docker.internal
MYSQL_PORT=3306
MYSQL_DB=producao
MYSQL_USER=
MYSQL_PASS=

# SIA schema overrides (defaults = banco producao/DATASUS: s_prd + prestador + procedimento)
# SIA_TABLE_PRD=s_prd
# SIA_TABLE_PRESTADOR=prestador
# SIA_TABLE_PROCEDIMENTO=procedimento
# SIA_COL_COMPETENCIA=prd_cmp
# SIA_COL_PRD_UID=prd_uid
# SIA_COL_PRESTADOR_PK=re_cunid
# SIA_COL_COD_PROC=prd_pa
# SIA_COL_PROC_PK=codigo
# SIA_COL_QTD=PRD_QT_A
# SIA_COL_VALOR=PRD_VL_A
# SIA_COL_IDADE=PRD_IDADE
# SIA_COL_CBO=prd_cbo
# SIA_COL_UNIDADE=re_cnome
# SIA_COL_DESC_PROC=procedimento
# SIA_COL_PRESTADOR_ATIVO=ativo
# SIA_COL_SEXO=          # vazio: s_prd não tem sexo → default 'I'

# SIA importação de produção (sync_sia_mysql.py — /importacao)
# SIA_EXTRACT_BLOCK_SIZE=10000   # linhas agregadas por página no MySQL (default 10000)
# SIA_PG_BATCH_SIZE=1000         # linhas por chunk no INSERT PostgreSQL (default 1000)
# Servidor fraco / timeout na extração MySQL: reduza, ex. SIA_EXTRACT_BLOCK_SIZE=2000 e SIA_PG_BATCH_SIZE=500
# Requer rebuild/restart do container api após alterar. nginx: timeout estendido em /api/sia/sincronizar.

# Cadastro sync — perfil derivado de prestador.tipouni (migration 004)
# CADASTRO_PERFIL_MAP={"tipouni":{"1":"APS","2":"MAC","3":"Hospitalar"},"default":"Outro"}
# CADASTRO_SYNC_SCRIPT=/app/sync_cadastros_mysql.py

# --- API ---
PORT=3001
NODE_ENV=production

# --- JWT ---
JWT_SECRET=change_me_use_random_string_at_least_32_chars
JWT_EXPIRES_IN=8h

# --- Python ETL ---
PYTHON_BIN=python3
UPLOAD_DIR=/app/uploads

# --- Frontend / Web ---
# Docker/nginx serve em same-origin e faz proxy para /api e /auth.
VITE_API_BASE=
WEB_PORT=8080

# Tag das imagens pré-compiladas (build local → deploy remoto sem compilar).
# Deve coincidir com a versão do pacote release (MANIFEST.txt / pasta release).
SIMPA_VERSION=latest
