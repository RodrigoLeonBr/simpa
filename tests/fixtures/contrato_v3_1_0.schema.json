{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": [
    "plataforma",
    "versao_schema",
    "competencia",
    "municipio",
    "filtros_ativos",
    "kpis_gerais",
    "modulos",
    "emendas_parlamentares",
    "indicadores_qualidade"
  ],
  "properties": {
    "plataforma": { "type": "string" },
    "versao_schema": { "const": "3.1.0" },
    "competencia": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
    "municipio": { "type": "string" },
    "filtros_ativos": {
      "type": "object",
      "required": ["unidade", "equipe"],
      "properties": {
        "unidade": { "type": "string" },
        "equipe": { "type": "string" }
      }
    },
    "kpis_gerais": {
      "type": "object",
      "properties": {
        "total_atendimentos_aps": { "type": ["integer", "null"] },
        "total_procedimentos_ambulatoriais": { "type": ["integer", "null"] },
        "total_participantes_coletivos": { "type": ["integer", "null"] },
        "atendimentos_odonto": { "type": ["integer", "null"] }
      }
    },
    "modulos": {
      "type": "object",
      "required": [
        "atencao_primaria_esus",
        "ambulatorial_sia",
        "hospitalar_sihd",
        "financiamento_metas"
      ]
    },
    "emendas_parlamentares": { "type": "array" },
    "indicadores_qualidade": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "cod",
          "nomeCurto",
          "nome",
          "categoria",
          "meta",
          "exec",
          "num",
          "den",
          "fonte",
          "periodicidade"
        ],
        "properties": {
          "cod": { "type": "string" },
          "meta": { "type": ["number", "null"] },
          "exec": { "type": ["number", "null"] }
        }
      }
    }
  }
}
